{
  "name": "openclaw-bridge",
  "version": "1.0.0",
  "description": "Universal WebSocket bridge server for openclaw channel plugins — dynamically loads installed plugins",
  "type": "module",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sagerenn/openclaw-bridge.git"
  },
  "homepage": "https://github.com/sagerenn/openclaw-bridge#readme",
  "bugs": { "url": "https://github.com/sagerenn/openclaw-bridge/issues" },
  "publishConfig": { "access": "public", "provenance": true },
  "files": [
    "dist",
    "src",
    "config.example.json",
    "README.md",
    "LICENSE"
  ],
  "main": "dist/server.js",
  "bin": {
    "openclaw-bridge": "dist/server.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsc --watch",
    "test:e2e": "node dist/test/e2e-test.js",
    "test:e2e:spec": "node dist/test/e2e-test-spec.js",
    "test:e2e:feishu": "node dist/test/e2e-test-feishu.js",
    "test:e2e:qqbot": "node dist/test/e2e-test-qqbot.js",
    "test:e2e:weixin": "node dist/test/e2e-test-weixin.js",
    "test:e2e:irc": "node dist/test/e2e-test-irc.js",
    "test:e2e:mattermost": "node dist/test/e2e-test-mattermost.js",
    "test:e2e:telegram": "node dist/test/e2e-test-telegram.js",
    "test:e2e:whatsapp": "node dist/test/e2e-test-whatsapp.js",
    "patch:lark": "node dist/util/patch-lark-plugin.js",
    "postinstall": "node dist/util/patch-lark-plugin.js || true",
    "postpublish": "node dist/util/patch-lark-plugin.js || true",
    "install:liangzimixin": "npm install liangzimixin",
    "install:weixin": "npm install @tencent-weixin/openclaw-weixin",
    "install:whatsapp": "npm install @openclaw/whatsapp",
    "install:lark": "npm install @larksuite/openclaw-lark && npm run build && node dist/util/patch-lark-plugin.js"
  },
  "dependencies": {
    "@larksuite/openclaw-lark": "^2026.6.10",
    "@openclaw/whatsapp": "^2026.6.10",
    "@tencent-connect/openclaw-qqbot": "^1.7.2",
    "@tencent-weixin/openclaw-weixin": "^2.4.6",
    "@types/qrcode": "^1.5.6",
    "baileys": "^7.0.0-rc13",
    "openclaw": "^2026.6.10",
    "qrcode": "^1.5.4",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.9.3"
  }
}
