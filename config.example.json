{
  "server": {
    "host": "0.0.0.0",
    "port": 9300,
    "path": "/bridge",
    "maxClients": 50,
    "clientHeartbeatMs": 30000,
    "maxMessageSize": 10485760
  },
  "channels": {
    "liangzimixin": {
      "enabled": true,
      "accounts": {
        "default": {
          "appId": "YOUR_LIANGZIMIXIN_APP_ID",
          "appSecret": "YOUR_LIANGZIMIXIN_APP_SECRET",
          "quantumAccount": "",
          "botUserId": "",
          "env": "production",
          "encryptionMode": "quantum_and_plain"
        }
      }
    },
    "openclaw-weixin": {
      "enabled": true,
      "accounts": {
        "default": {}
      },
      "_comment": "WeChat uses QR code login — leave accounts empty and visit /plugin/openclaw-weixin/default/qr to scan"
    }
  },
  "logging": {
    "level": "info"
  }
}
